# Copy to backend/.env and fill in. All values are optional — the app runs
# without them, with the weather boost disabled and default URLs.

# OpenWeatherMap free-tier API key (https://openweathermap.org/api)
OPENWEATHERMAP_API_KEY=

# Absolute URL used inside email buttons. Must point to this backend.
BACKEND_BASE_URL=http://localhost:8000

# External data sources — override if the hackathon uses a different host.
PRODUCTS_URL=https://api.nagya.app/products
USERS_URL=https://api.nagya.app/users

# City used for the weather boost (comma separated "City,CountryCode").
WEATHER_CITY=Budapest,HU

# HTTP timeout (seconds) for upstream calls.
HTTP_TIMEOUT_SECONDS=10
